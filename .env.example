# Nexus TopUp — Environment Variables
# Bu faylni `.env` ga nusxalang va qiymatlarni to'ldiring.

# Backend API asosiy URL manzili
VITE_API_BASE_URL=http://localhost:3001

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=  

# Telegram bot username (qo'llab-quvvatlash linki uchun)
VITE_TELEGRAM_BOT_USERNAME=uzpinbot

# Feature flags
VITE_ENABLE_GOOGLE_AUTH=false
